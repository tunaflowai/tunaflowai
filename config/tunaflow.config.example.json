{
  "runtime": {
    "name": "TunaFlowAI",
    "workspace": ".",
    "dataDir": ".tunaflow",
    "proactive": true,
    "verifyToolResults": true,
    "maxActionsPerRun": 8,
    "defaultPersona": "operator"
  },
  "server": {
    "host": "127.0.0.1",
    "port": 8787,
    "apiTokenEnv": "TUNAFLOW_API_TOKEN",
    "corsOrigin": "http://127.0.0.1:8787",
    "bodyLimitBytes": 1048576,
    "dashboard": true
  },
  "context": {
    "maxRecentEvents": 8,
    "maxTextChars": 1800
  },
  "skills": {
    "enabled": true,
    "bundled": true,
    "allowWorkspaceSkills": false,
    "allowUserSkills": false,
    "maxSkills": 3,
    "maxSkillChars": 3500,
    "paths": [],
    "acquired": true,
    "acquiredDir": ".tunaflow/skills/acquired"
  },
  "channels": {
    "webhook": {
      "enabled": true
    },
    "telegram": {
      "enabled": false,
      "tokenEnv": "TELEGRAM_BOT_TOKEN"
    },
    "discord": {
      "enabled": false,
      "tokenEnv": "DISCORD_BOT_TOKEN"
    },
    "slack": {
      "enabled": false,
      "botTokenEnv": "SLACK_BOT_TOKEN"
    },
    "whatsappCloud": {
      "enabled": false,
      "accessTokenEnv": "WHATSAPP_ACCESS_TOKEN",
      "phoneNumberIdEnv": "WHATSAPP_PHONE_NUMBER_ID",
      "verifyTokenEnv": "WHATSAPP_VERIFY_TOKEN"
    }
  },
  "tokenBudget": {
    "maxInputTokens": 8000,
    "maxOutputTokens": 1200,
    "maxModelCallsPerEvent": 3
  },
  "fallback": {
    "timeoutMs": 20000,
    "cooldownMs": 30000,
    "maxFailuresBeforeCooldown": 2
  },
  "models": [
    {
      "name": "openai-main",
      "provider": "openai",
      "apiKeyEnv": "OPENAI_API_KEY",
      "model": "YOUR_OPENAI_MODEL",
      "enabled": false,
      "jsonMode": true,
      "jsonSchemaMode": true
    },
    {
      "name": "gemini-flash",
      "provider": "gemini",
      "apiKeyEnv": "GEMINI_API_KEY",
      "model": "YOUR_GEMINI_MODEL",
      "enabled": false
    },
    {
      "name": "anthropic-sonnet",
      "provider": "anthropic",
      "apiKeyEnv": "ANTHROPIC_API_KEY",
      "model": "YOUR_CLAUDE_MODEL",
      "enabled": false
    },
    {
      "name": "qwen-plus",
      "provider": "qwen",
      "apiKeyEnv": "DASHSCOPE_API_KEY",
      "model": "YOUR_QWEN_MODEL",
      "enabled": false,
      "jsonMode": true
    },
    {
      "name": "minimax",
      "provider": "minimax",
      "apiKeyEnv": "MINIMAX_API_KEY",
      "model": "YOUR_MINIMAX_MODEL",
      "enabled": false,
      "jsonMode": true
    },
    {
      "name": "deepseek",
      "provider": "deepseek",
      "apiKeyEnv": "DEEPSEEK_API_KEY",
      "model": "YOUR_DEEPSEEK_MODEL",
      "enabled": false,
      "jsonMode": true
    },
    {
      "name": "kimi",
      "provider": "kimi",
      "apiKeyEnv": "MOONSHOT_API_KEY",
      "model": "YOUR_KIMI_MODEL",
      "enabled": false,
      "jsonMode": true
    },
    {
      "name": "ollama-local",
      "provider": "ollama",
      "baseUrl": "http://127.0.0.1:11434/v1",
      "model": "llama3.2",
      "enabled": false,
      "jsonMode": true
    },
    {
      "name": "local-mock-fallback",
      "provider": "mock",
      "behavior": "ok",
      "enabled": true
    }
  ],
  "chains": {
    "default": [
      "openai-main",
      "gemini-flash",
      "deepseek",
      "local-mock-fallback"
    ],
    "cheap": [
      "gemini-flash",
      "qwen-plus",
      "ollama-local",
      "local-mock-fallback"
    ],
    "strong": [
      "anthropic-sonnet",
      "openai-main",
      "deepseek",
      "kimi",
      "local-mock-fallback"
    ],
    "local": [
      "ollama-local",
      "local-mock-fallback"
    ]
  },
  "permissions": {
    "autoApproveMedium": false,
    "autoApproveHigh": false,
    "blockedTools": []
  },
  "tools": {
    "commandAllowlist": [
      "node",
      "npm",
      "pnpm",
      "yarn",
      "git",
      "python",
      "python3"
    ],
    "commandDenyPatterns": [
      "git push",
      "git reset --hard",
      "npm publish",
      "pnpm publish",
      "yarn publish",
      "rm -rf",
      "curl | sh",
      "wget | sh"
    ],
    "defaultCommandTimeoutMs": 30000,
    "maxCommandOutputChars": 6000
  },
  "personas": {
    "enabled": true,
    "default": "operator",
    "bundled": true,
    "allowWorkspacePersonas": false,
    "allowUserPersonas": false,
    "maxPersonaChars": 5000,
    "paths": []
  }
}
