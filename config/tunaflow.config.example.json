{
  "runtime": {
    "name": "TunaFlowAI",
    "workspace": ".",
    "dataDir": ".tunaflow",
    "proactive": true,
    "verifyToolResults": true,
    "maxActionsPerRun": 8
  },
  "server": {
    "host": "127.0.0.1",
    "port": 8787,
    "apiTokenEnv": "TUNAFLOW_API_TOKEN",
    "corsOrigin": "http://127.0.0.1:8787",
    "bodyLimitBytes": 1048576
  },
  "context": {
    "maxRecentEvents": 8,
    "maxTextChars": 1800
  },
  "tokenBudget": {
    "maxInputTokens": 8000,
    "maxOutputTokens": 1200,
    "maxModelCallsPerEvent": 3
  },
  "fallback": {
    "timeoutMs": 20000,
    "cooldownMs": 30000,
    "maxFailuresBeforeCooldown": 2
  },
  "models": [
    {
      "name": "primary-openai-compatible",
      "provider": "openai-compatible",
      "baseUrl": "https://api.openai.com/v1",
      "apiKeyEnv": "OPENAI_API_KEY",
      "model": "YOUR_MODEL_NAME",
      "enabled": false,
      "jsonMode": true
    },
    {
      "name": "local-mock-fallback",
      "provider": "mock",
      "behavior": "ok",
      "enabled": true
    }
  ],
  "chains": {
    "default": ["primary-openai-compatible", "local-mock-fallback"],
    "cheap": ["local-mock-fallback"],
    "strong": ["primary-openai-compatible", "local-mock-fallback"]
  },
  "permissions": {
    "autoApproveMedium": false,
    "autoApproveHigh": false,
    "blockedTools": []
  },
  "tools": {
    "commandAllowlist": ["node", "npm", "pnpm", "yarn", "git", "python", "python3"],
    "defaultCommandTimeoutMs": 30000,
    "maxCommandOutputChars": 6000
  }
}
