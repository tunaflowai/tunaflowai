{
  "runtime": {
    "name": "TunaFlowAI",
    "workspace": ".",
    "dataDir": ".tunaflow",
    "proactive": true,
    "verifyToolResults": true,
    "maxActionsPerRun": 8,
    "defaultPersona": "operator"
  },
  "identity": {
    "agentName": "Tuna",
    "displayName": "Tuna",
    "pronouns": "they/them",
    "bio": "A local-first AI work operating agent with model fallback, persona switching, skills, approvals, and audit logs.",
    "personality": {
      "tone": "calm, practical, safety-aware, token-efficient, and action-oriented",
      "traits": [
        "careful",
        "proactive",
        "evidence-driven",
        "concise"
      ],
      "language": "English by default; adapt to user language when asked",
      "boundaries": [
        "Never bypass approval policy",
        "Never expose secrets",
        "Never claim completed work without evidence"
      ]
    }
  },
  "server": {
    "host": "127.0.0.1",
    "port": 8787,
    "apiTokenEnv": "TUNAFLOW_API_TOKEN",
    "corsOrigin": "http://127.0.0.1:8787",
    "bodyLimitBytes": 1048576,
    "dashboard": true
  },
  "context": {
    "maxRecentEvents": 8,
    "maxTextChars": 1800
  },
  "policy": {
    "file": "policies/default.policy.json"
  },
  "sandbox": {
    "mode": "local",
    "dockerImage": "node:22-bookworm-slim",
    "network": "none",
    "readOnly": false,
    "commandAllowlist": [
      "node",
      "npm",
      "pnpm",
      "yarn",
      "git",
      "python",
      "python3",
      "codex"
    ],
    "commandDenyPatterns": [
      "git push",
      "git reset --hard",
      "npm publish",
      "pnpm publish",
      "yarn publish",
      "rm -rf",
      "curl | sh",
      "wget | sh",
      "sudo ",
      "chmod 777"
    ],
    "defaultTimeoutMs": 30000,
    "maxTimeoutMs": 120000,
    "maxOutputChars": 6000
  },
  "browser": {
    "maxResponseChars": 12000,
    "blockedHosts": [
      "169.254.169.254",
      "localhost",
      "127.0.0.1",
      "0.0.0.0"
    ],
    "allowedHosts": []
  },
  "secrets": {
    "keyEnv": "TUNAFLOW_SECRETS_KEY",
    "allowLocalKeyFile": false
  },
  "skillTrust": {
    "signingKeyEnv": "TUNAFLOW_SKILL_SIGNING_KEY"
  },
  "skills": {
    "enabled": true,
    "bundled": true,
    "allowWorkspaceSkills": false,
    "allowUserSkills": false,
    "maxSkills": 4,
    "maxSkillChars": 3500,
    "paths": [],
    "acquired": true,
    "acquiredDir": ".tunaflow/skills/acquired"
  },
  "channels": {
    "autoStart": true,
    "webhook": {
      "enabled": true
    },
    "telegram": {
      "enabled": false,
      "tokenEnv": "TELEGRAM_BOT_TOKEN",
      "secretTokenEnv": "TELEGRAM_WEBHOOK_SECRET",
      "polling": false
    },
    "discord": {
      "enabled": false,
      "tokenEnv": "DISCORD_BOT_TOKEN",
      "publicKeyEnv": "DISCORD_PUBLIC_KEY",
      "verifySignatures": true
    },
    "slack": {
      "enabled": false,
      "botTokenEnv": "SLACK_BOT_TOKEN",
      "signingSecretEnv": "SLACK_SIGNING_SECRET",
      "verifySignatures": true
    },
    "whatsappCloud": {
      "enabled": false,
      "accessTokenEnv": "WHATSAPP_ACCESS_TOKEN",
      "phoneNumberIdEnv": "WHATSAPP_PHONE_NUMBER_ID",
      "verifyTokenEnv": "WHATSAPP_VERIFY_TOKEN",
      "appSecretEnv": "WHATSAPP_APP_SECRET",
      "verifySignatures": true
    }
  },
  "tokenBudget": {
    "maxInputTokens": 8000,
    "maxOutputTokens": 1200,
    "maxModelCallsPerEvent": 3
  },
  "fallback": {
    "timeoutMs": 20000,
    "cooldownMs": 30000,
    "maxFailuresBeforeCooldown": 2
  },
  "models": [
    {
      "name": "openai-main",
      "provider": "openai",
      "apiKeyEnv": "OPENAI_API_KEY",
      "model": "YOUR_OPENAI_MODEL",
      "enabled": false,
      "jsonMode": true,
      "jsonSchemaMode": true
    },
    {
      "name": "openai-codex",
      "provider": "codex-cli",
      "auth": "chatgpt-oauth",
      "commandEnv": "CODEX_BIN",
      "model": "gpt-5.5",
      "enabled": false,
      "timeoutMs": 120000,
      "args": [
        "exec",
        "--ephemeral",
        "--sandbox",
        "read-only"
      ],
      "passOpenAiApiKey": false,
      "note": "Requires npm i -g @openai/codex and codex login. This uses the local ChatGPT OAuth session, not OPENAI_API_KEY."
    },
    {
      "name": "gemini-flash",
      "provider": "gemini",
      "apiKeyEnv": "GEMINI_API_KEY",
      "model": "YOUR_GEMINI_MODEL",
      "enabled": false
    },
    {
      "name": "anthropic-sonnet",
      "provider": "anthropic",
      "apiKeyEnv": "ANTHROPIC_API_KEY",
      "model": "YOUR_CLAUDE_MODEL",
      "enabled": false
    },
    {
      "name": "qwen-plus",
      "provider": "qwen",
      "apiKeyEnv": "DASHSCOPE_API_KEY",
      "model": "YOUR_QWEN_MODEL",
      "enabled": false,
      "jsonMode": true
    },
    {
      "name": "minimax",
      "provider": "minimax",
      "apiKeyEnv": "MINIMAX_API_KEY",
      "model": "YOUR_MINIMAX_MODEL",
      "enabled": false,
      "jsonMode": true
    },
    {
      "name": "deepseek",
      "provider": "deepseek",
      "apiKeyEnv": "DEEPSEEK_API_KEY",
      "model": "YOUR_DEEPSEEK_MODEL",
      "enabled": false,
      "jsonMode": true
    },
    {
      "name": "kimi",
      "provider": "kimi",
      "apiKeyEnv": "MOONSHOT_API_KEY",
      "model": "YOUR_KIMI_MODEL",
      "enabled": false,
      "jsonMode": true
    },
    {
      "name": "ollama-local",
      "provider": "ollama",
      "baseUrl": "http://127.0.0.1:11434/v1",
      "model": "llama3.2",
      "enabled": false,
      "jsonMode": true
    },
    {
      "name": "local-mock-fallback",
      "provider": "mock",
      "behavior": "ok",
      "enabled": true
    }
  ],
  "chains": {
    "default": [
      "openai-main",
      "gemini-flash",
      "deepseek",
      "local-mock-fallback"
    ],
    "cheap": [
      "gemini-flash",
      "qwen-plus",
      "ollama-local",
      "local-mock-fallback"
    ],
    "strong": [
      "anthropic-sonnet",
      "openai-main",
      "deepseek",
      "kimi",
      "local-mock-fallback"
    ],
    "local": [
      "ollama-local",
      "local-mock-fallback"
    ],
    "code": [
      "openai-codex",
      "openai-main",
      "anthropic-sonnet",
      "deepseek",
      "local-mock-fallback"
    ],
    "codex": [
      "openai-codex",
      "openai-main",
      "local-mock-fallback"
    ],
    "coding": [
      "openai-codex",
      "openai-main",
      "ollama-local",
      "local-mock-fallback"
    ]
  },
  "permissions": {
    "autoApproveMedium": false,
    "autoApproveHigh": false,
    "blockedTools": []
  },
  "tools": {
    "defaultCommandTimeoutMs": 30000,
    "maxCommandOutputChars": 6000,
    "telegram": {
      "tokenEnv": "TELEGRAM_BOT_TOKEN",
      "chatIdEnv": "TELEGRAM_CHAT_ID"
    },
    "extendedJobTools": true
  },
  "personas": {
    "enabled": true,
    "default": "operator",
    "bundled": true,
    "allowWorkspacePersonas": false,
    "allowUserPersonas": false,
    "maxPersonaChars": 5000,
    "paths": []
  },
  "auth": {
    "enabled": false,
    "passwordEnv": "TUNAFLOW_DASHBOARD_PASSWORD",
    "sessionSecretEnv": "TUNAFLOW_SESSION_SECRET",
    "ttlMs": 43200000
  },
  "tasks": {
    "autoCreateFromUserEvents": true,
    "defaultBudget": {
      "maxModelCalls": 8,
      "maxInputTokens": 30000,
      "maxOutputTokens": 6000,
      "maxToolCalls": 20,
      "maxRuntimeMs": 300000
    }
  }
}
