# Optional. Only needed when using the openai-compatible provider.
OPENAI_API_KEY=

# Runtime settings.
TUNAFLOW_PORT=8787
TUNAFLOW_HOST=127.0.0.1
TUNAFLOW_WORKSPACE=.
TUNAFLOW_CONFIG=config/tunaflow.config.example.json

# Optional local API protection. If set, POST/unsafe endpoints require:
# Authorization: Bearer $TUNAFLOW_API_TOKEN
TUNAFLOW_API_TOKEN=

# Safety defaults. Keep these false for real usage.
TUNAFLOW_AUTO_APPROVE_MEDIUM=false
TUNAFLOW_AUTO_APPROVE_HIGH=false
